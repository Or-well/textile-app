{
  "schema_version": 1,
  "roles": {
    "order": [
      "owner",
      "admin",
      "tech_lead",
      "translator",
      "proofreader",
      "reviewer",
      "publisher",
      "term_manager",
      "readonly"
    ],
    "labels": {
      "owner": "项目负责人",
      "admin": "管理员",
      "tech_lead": "技术负责人",
      "translator": "翻译",
      "proofreader": "校对",
      "reviewer": "审核",
      "publisher": "发布负责人",
      "term_manager": "术语负责人",
      "readonly": "只读成员"
    }
  },
  "groups": [
    {
      "id": "project",
      "label": "项目",
      "permissions": [
        { "action": "app.cache.clear", "label": "清理缓存" },
        { "action": "project.read", "label": "查看项目" },
        { "action": "project.manage", "label": "管理项目" },
        { "action": "project.backup", "label": "导出项目备份" },
        { "action": "project.delete", "label": "移除项目记录" },
        { "action": "project.maintenance", "label": "项目维护" }
      ]
    },
    {
      "id": "member-role",
      "label": "成员与权限",
      "permissions": [
        { "action": "member.view", "label": "查看成员" },
        { "action": "member.manage", "label": "管理成员" },
        { "action": "member.reset_password", "label": "重置密码" },
        { "action": "role.view", "label": "查看角色权限" },
        { "action": "role.manage", "label": "管理角色权限" }
      ]
    },
    {
      "id": "file",
      "label": "文件",
      "permissions": [
        { "action": "file.view", "label": "查看文件" },
        { "action": "file.create", "label": "新建文件" },
        { "action": "file.update", "label": "更新文件" },
        { "action": "file.import_translation", "label": "导入译文" },
        { "action": "file.rename", "label": "重命名文件" },
        { "action": "file.lock", "label": "锁定文件" },
        { "action": "file.hide", "label": "隐藏文件" },
        { "action": "file.delete", "label": "删除文件" }
      ]
    },
    {
      "id": "entry",
      "label": "词条",
      "permissions": [
        { "action": "entry.read", "label": "查看词条" },
        { "action": "entry.edit", "label": "编辑词条" },
        { "action": "entry.translate", "label": "翻译" },
        { "action": "entry.proofread", "label": "校对" },
        { "action": "entry.review", "label": "审核" },
        { "action": "entry.rollback", "label": "退回词条" },
        { "action": "entry.lock", "label": "锁定词条" },
        { "action": "entry.hide", "label": "隐藏词条" },
        { "action": "entry.mark_disputed", "label": "标记争议" },
        { "action": "entry.resolve_dispute", "label": "解决争议" }
      ]
    },
    {
      "id": "term",
      "label": "术语",
      "permissions": [
        { "action": "term.read", "label": "查看术语" },
        { "action": "term.create", "label": "新建术语" },
        { "action": "term.update", "label": "编辑术语" },
        { "action": "term.delete", "label": "删除术语" },
        { "action": "term.import", "label": "导入术语" },
        { "action": "term.export", "label": "导出术语" }
      ]
    },
    {
      "id": "context",
      "label": "词条上下文",
      "permissions": [
        { "action": "context.view", "label": "查看词条上下文" },
        { "action": "context.create", "label": "新增词条上下文" },
        { "action": "context.update", "label": "编辑词条上下文" },
        { "action": "context.delete", "label": "删除词条上下文" }
      ]
    },
    {
      "id": "task",
      "label": "任务",
      "permissions": [
        { "action": "task.view", "label": "查看任务" },
        { "action": "task.create", "label": "新建任务" },
        { "action": "task.update", "label": "编辑任务" },
        { "action": "task.assign", "label": "分配任务" },
        { "action": "task.submit", "label": "提交任务" },
        { "action": "task.complete", "label": "完成任务" },
        { "action": "task.reclaim", "label": "收回任务" },
        { "action": "task.delete", "label": "删除任务" },
        { "action": "task.reopen", "label": "重新打开任务" }
      ]
    },
    {
      "id": "comment",
      "label": "批注",
      "permissions": [
        { "action": "comment.view", "label": "查看批注" },
        { "action": "comment.create", "label": "新增批注" },
        { "action": "comment.reply", "label": "回复批注" },
        { "action": "comment.resolve", "label": "解决批注" },
        { "action": "comment.reopen", "label": "重新打开批注" },
        { "action": "comment.delete_own", "label": "删除自己的批注" },
        { "action": "comment.delete_any", "label": "删除任意批注" }
      ]
    },
    {
      "id": "change-package",
      "label": "修改包",
      "permissions": [
        { "action": "change_package.export", "label": "导出修改包" },
        { "action": "change_package.import", "label": "导入任意修改包" },
        { "action": "change_package.export_member_changes", "label": "导出普通修改包" },
        { "action": "change_package.import_member_changes", "label": "导入普通修改包" },
        { "action": "change_package.export_project_update", "label": "发布项目更新包" },
        { "action": "change_package.import_project_update", "label": "接收项目更新包" },
        { "action": "change_package.export_maintenance", "label": "导出项目维护修改" },
        { "action": "change_package.import_maintenance", "label": "导入项目维护修改" },
        { "action": "change_package.review", "label": "预览修改包内容" },
        { "action": "change_package.sign", "label": "签名修改包/项目更新包" },
        { "action": "change_package.verify", "label": "验证修改包签名" },
        { "action": "change_package.dangerous_import", "label": "危险导入完整性失败的包" }
      ]
    },
    {
      "id": "release",
      "label": "成品导出",
      "permissions": [
        { "action": "release.export", "label": "导出成品" }
      ]
    },
    {
      "id": "key",
      "label": "签名密钥",
      "permissions": [
        { "action": "key.view", "label": "查看密钥状态" },
        { "action": "key.generate", "label": "生成密钥" },
        { "action": "key.import_private", "label": "导入私钥文件" },
        { "action": "key.export_private", "label": "导出私钥文件" },
        { "action": "key.register_public", "label": "登记成员公钥" },
        { "action": "key.rotate", "label": "生成新密钥" },
        { "action": "key.revoke", "label": "撤销密钥" }
      ]
    },
    {
      "id": "maintenance",
      "label": "兼容与维护",
      "permissions": [
        { "action": "file.manage_folder", "label": "管理文件分组" },
        { "action": "entry.update_status", "label": "更新词条状态" },
        { "action": "term.manage", "label": "管理术语" },
        { "action": "task.read", "label": "读取任务" },
        { "action": "task.manage", "label": "管理任务" },
        { "action": "comment.read", "label": "查看批注（兼容权限）" },
        { "action": "comment.write", "label": "写入批注（兼容权限）" },
        { "action": "stats.read", "label": "查看统计" },
        { "action": "tech.maintain", "label": "技术维护" }
      ]
    }
  ],
